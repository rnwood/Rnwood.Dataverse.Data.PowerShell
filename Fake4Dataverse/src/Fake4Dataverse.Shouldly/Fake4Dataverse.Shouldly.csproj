    <RootNamespace>Fake4Dataverse.Shouldly</RootNamespace>
    <AssemblyName>Fake4Dataverse.Shouldly</AssemblyName>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <PackageId>Fake4Dataverse.Shouldly</PackageId>
    <Version>0.1.0</Version>
    <Authors>Fake4Dataverse Contributors</Authors>
    <Description>Shouldly helper assertions for Fake4Dataverse operation log verification.</Description>
    <PackageTags>dataverse;dynamics365;testing;fake;shouldly;xrm</PackageTags>
